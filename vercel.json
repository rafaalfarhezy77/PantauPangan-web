{
  "functions": {
    "api/**/*.php": {
      "runtime": "vercel-php@0.6.2"
    }
  },
  "routes": [
    {
      "src": "/",
      "dest": "/index.html"
    },
    {
      "src": "/(login|dashboard|dashboardAdmin|detail|edit_user|coba_api|provinsi_api|logout)",
      "dest": "/api/$1.php"
    },
    {
      "src": "/Proses/(.*)",
      "dest": "/api/Proses/$1"
    },
    {
      "src": "/(.*)",
      "dest": "/$1"
    }
  ]
}
